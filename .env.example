# ============================================================
# Asia Decor Samarkand — .env.example
# Nusxa oling: cp .env.example .env
# Keyin qiymatlarni to'ldiring!
# ============================================================

# 🔐 Django Secret Key (yangi yarating: python -c "from django.core.utils.crypto import get_random_string; print(get_random_string(50))")
SECRET_KEY=django-insecure-change-this-key-in-production

# 🐞 Debug rejimi (production'da False qiling)
DEBUG=True

# 🌐 Sayt URL (Render domeningiz)
SITE_URL=https://asia-decor-samarkand-3.onrender.com

# 🤖 User Bot Token (@BotFather dan oling)
USER_BOT_TOKEN=

# 🤖 Admin Bot Token (@BotFather dan oling)
ADMIN_BOT_TOKEN=

# 📢 Admin Chat ID (admin botga /myid yozing)
ADMIN_CHAT_ID=

# 👥 Ruxsatli admin Telegram ID'lari (vergul bilan ajrating)
# Misol: ALLOWED_ADMIN_IDS=123456789,987654321
ALLOWED_ADMIN_IDS=

# 🗄 (Ixtiyoriy) PostgreSQL database URL
# DATABASE_URL=postgresql://user:password@host:5432/dbname
